---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'kumiko', description = '个人主页 — 记录学习与生活' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="header">
      <div class="container header-inner">
        <a href={import.meta.env.BASE_URL} class="logo">kumiko</a>
        <nav class="nav">
          <a href={import.meta.env.BASE_URL}>首页</a>
          <a href={`${import.meta.env.BASE_URL}/blog`}>博客</a>
          <a href={`${import.meta.env.BASE_URL}/about`}>关于</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <p>&copy; {new Date().getFullYear()} kumiko. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  .header {
    border-bottom: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .logo {
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--color-text);
  }

  .logo:hover {
    color: var(--color-accent);
  }

  .nav {
    display: flex;
    gap: var(--gap-lg);
  }

  .nav a {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    position: relative;
  }

  .nav a:hover {
    color: var(--color-accent);
  }

  .nav a[aria-current="page"] {
    color: var(--color-accent);
    font-weight: 600;
  }

  .nav a[aria-current="page"]::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }

  main {
    flex: 1;
  }

  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--gap-lg) 0;
    margin-top: var(--gap-xl);
  }

  .footer-inner {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }
</style>
